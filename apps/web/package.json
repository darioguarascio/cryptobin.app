{
  "name": "@cryptobin/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "cp ../../scripts/install.sh public/install.sh",
    "dev": "astro dev --host 0.0.0.0",
    "prebuild": "cp ../../scripts/install.sh public/install.sh",
    "build": "astro check && astro build",
    "preview": "astro preview --host 0.0.0.0",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@astrojs/node": "^11.0.1",
    "@astrojs/react": "^6.0.0",
    "astro": "^7.0.5",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^0.544.0",
    "nodemailer": "^9.0.3",
    "otplib": "^13.4.1",
    "postgres": "^3.4.9",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^24.5.2",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitest/coverage-v8": "^3.2.4",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
